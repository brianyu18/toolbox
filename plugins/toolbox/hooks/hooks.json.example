{
  "_comment": "Optional hard-trigger for the brains router. Rename this file to hooks.json to activate. Fires on every user prompt and injects a short reminder into the model's context suggesting it invoke /brains for non-trivial tasks. Enable only if soft-trigger (description-based) proves unreliable in practice.",
  "UserPromptSubmit": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "echo 'Reminder: if this looks like a non-trivial development task or project kickoff, invoke the brains router skill before acting.'"
        }
      ]
    }
  ]
}
